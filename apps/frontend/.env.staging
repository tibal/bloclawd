# Staging fetches /reports/v1/* same-origin via the frontend Worker R2
# proxy (apps/frontend/worker/index.ts). The staging R2 bucket has no
# public r2.dev / custom-domain attach — reads only flow through this
# Worker, which is policy-gated by Cloudflare Access on staging.bloclawd.com.
# Empty value preserves the same-origin path the SPA constructs by default.
VITE_R2_BASE_URL=
