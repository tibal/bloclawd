{
  "rules": [
    {
      "allowed": {
        "origins": [
          "https://staging.bloclawd.com"
        ],
        "methods": ["GET", "HEAD"],
        "headers": ["accept"]
      },
      "exposeHeaders": ["cache-control", "content-type", "etag", "last-modified"],
      "maxAgeSeconds": 3000
    }
  ]
}
