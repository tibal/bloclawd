# Copy to .env.local and fill in real values. .env.local is gitignored.
# All keys here mirror what the code actually reads (apps/worker/README.md,
# apps/worker/tests/e2e_staging.rs). PlanetScale "Direct URL" format only —
# pooled URLs break DDL.
#
# Single-quote values: connection-string query params use `&`, which is a
# shell metacharacter when sourcing this file via `set -a; source .env.local`.

PLANETSCALE_STAGING_URL='postgresql://USER:PASSWORD@HOST.psdb.cloud:5432/DB?sslmode=require'
PLANETSCALE_MAIN_URL='postgresql://USER:PASSWORD@HOST.psdb.cloud:5432/DB?sslmode=require'

BLOCLAWD_STAGING_URL='https://bloclawd-worker-staging.<account>.workers.dev'
BLOCLAWD_MAIN_URL='https://bloclawd-worker.<account>.workers.dev'

ACCOUNT_HASH='<cloudflare-account-subdomain>'
STAGING_R2_BASE_URL='https://pub-<r2-dev-url-hash>.r2.dev'
